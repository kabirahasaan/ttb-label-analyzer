# Environment Configuration
# Copy this file to .env.local and fill in your values

# Database
DATABASE_URL="postgresql://user:password@localhost:5432/ttb_label_analyzer"
DATABASE_SHADOW_URL="postgresql://user:password@localhost:5432/ttb_label_analyzer_shadow"

# Node Environment
NODE_ENV="development"

# API Configuration
API_PORT=3001
API_HOST="0.0.0.0"

# Web Configuration
WEB_PORT=3000
NEXT_PUBLIC_API_URL="http://localhost:3001"

# Logging
LOG_LEVEL="debug"
LOG_FORMAT="json"

# OCR Configuration
TESSERACT_LANG="eng"
OCR_TIMEOUT=30000

# CORS
CORS_ORIGIN="http://localhost:3000"

# Upload Configuration
UPLOAD_MAX_FILES=50
UPLOAD_MAX_SIZE=52428800

# Application
APP_NAME="TTB Label Analyzer"
APP_VERSION="1.0.0"
