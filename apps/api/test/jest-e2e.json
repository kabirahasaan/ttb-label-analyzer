{
  "moduleFileExtensions": ["js", "json", "ts"],
  "rootDir": ".",
  "testEnvironment": "node",
  "testRegex": ".e2e-spec.ts$",
  "transform": {
    "^.+\\.(t|j)s$": "ts-jest"
  },
  "moduleNameMapper": {
    "^@ttb/(.*)$": "<rootDir>/../../../libs/$1/src"
  },
  "collectCoverageFrom": [
    "../src/**/*.(t|j)s",
    "!../src/**/*.spec.ts",
    "!../src/**/*.interface.ts",
    "!../src/**/index.ts",
    "!../src/main.ts"
  ],
  "coverageDirectory": "../coverage/integration"
}
