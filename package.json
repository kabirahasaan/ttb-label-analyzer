{
  "name": "@ttb-label-analyzer/monorepo",
  "version": "1.0.0",
  "description": "TTB Label Compliance Validation Platform",
  "author": "A. K. <kabirahasaan@gmail.com>",
  "license": "UNLICENSED",
  "private": true,
  "packageManager": "pnpm@8.15.0",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=8.0.0"
  },
  "scripts": {
    "predev": "node -e \"const major = Number(process.versions.node.split('.')[0]); if (major < 20) { console.error('Node.js 20+ is required. Run: nvm use'); process.exit(1); }\"",
    "dev": "nx run-many --targets=serve --projects=api,web --parallel=2",
    "build": "nx run-many --targets=build --projects=api,web",
    "build:web": "nx run web:build",
    "vercel-build": "npm run build:web && rm -rf .next && cp -R apps/web/.next .next",
    "test": "npm run test:unit && npm run test:integration && npm run test:e2e",
    "test:unit": "nx run-many --targets=test --all",
    "test:unit:watch": "nx run-many --targets=test --all --watch",
    "test:integration": "nx run api:test:e2e",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:chromium": "playwright test --project=chromium",
    "test:watch": "nx run-many --targets=test --all --watch",
    "test:coverage": "npm run test:coverage:unit && npm run test:coverage:integration",
    "test:coverage:unit": "nx run-many --targets=test --all --coverage --coverageDirectory=coverage/unit",
    "test:coverage:integration": "nx run api:test:e2e --coverage --coverageDirectory=coverage/integration",
    "test:coverage:report": "node scripts/merge-coverage.js",
    "lint": "nx run-many --targets=lint --all",
    "lint:fix": "nx run-many --targets=lint --all -- --fix",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "start": "cd apps/api && npm start",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f",
    "db:migrate": "nx run api:prisma:migrate",
    "db:seed": "nx run api:prisma:seed",
    "generate:test-data": "nx run test-data-generator:generate",
    "fetch:ttb-rules": "ts-node libs/ttb-rules/src/fetcher/fetch-ttb-rules.ts",
    "fetch:ttb-rules:cached-only": "npm run fetch:ttb-rules -- --cached-only",
    "fetch:ttb-rules:stats": "npm run fetch:ttb-rules -- --stats",
    "fetch:ttb-rules:export-csv": "npm run fetch:ttb-rules -- --export-csv",
    "ac:perf": "node scripts/acceptance/performance-check.js",
    "ac:a11y": "node scripts/acceptance/a11y-smoke.js",
    "prepare": "husky install"
  },
  "dependencies": {
    "@nestjs/common": "^10.2.10",
    "@nestjs/core": "^10.2.10",
    "@nestjs/platform-express": "^10.2.10",
    "@nestjs/swagger": "^7.1.11",
    "@prisma/client": "^5.7.0",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-navigation-menu": "^1.2.14",
    "@radix-ui/react-toast": "^1.2.15",
    "axios": "^1.6.2",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "lucide-react": "^0.577.0",
    "next": "^14.0.3",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-hook-form": "^7.48.0",
    "react-query": "^3.39.3",
    "reflect-metadata": "^0.1.13",
    "rxjs": "^7.8.1",
    "tailwind-merge": "^3.5.0",
    "tesseract.js": "^5.0.4",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@faker-js/faker": "^10.3.0",
    "@nestjs/cli": "^10.2.1",
    "@nestjs/schematics": "^10.0.2",
    "@nestjs/testing": "^10.2.10",
    "@next/eslint-plugin-next": "^14.0.3",
    "@playwright/test": "^1.40.1",
    "@tailwindcss/forms": "^0.5.6",
    "@testing-library/jest-dom": "^6.1.5",
    "@testing-library/react": "^14.1.2",
    "@types/jest": "^29.5.8",
    "@types/node": "^20.10.4",
    "@types/react": "^18.2.37",
    "@types/supertest": "^6.0.3",
    "@typescript-eslint/eslint-plugin": "^6.13.2",
    "@typescript-eslint/parser": "^6.13.2",
    "autoprefixer": "^10.4.16",
    "eslint": "^8.55.0",
    "eslint-config-next": "^14.0.3",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.0.1",
    "husky": "^8.0.3",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^30.2.0",
    "lint-staged": "^15.2.0",
    "nx": "^17.1.2",
    "postcss": "^8.4.31",
    "prettier": "^3.1.1",
    "prisma": "^5.7.0",
    "supertest": "^6.3.4",
    "tailwindcss": "^3.3.6",
    "ts-jest": "^29.1.1",
    "ts-loader": "^9.5.1",
    "ts-node": "^10.9.1",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.3.3",
    "vitest": "^1.0.4"
  }
}
